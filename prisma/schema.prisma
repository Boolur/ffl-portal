model Lead {
  id            String      @id @default(uuid())
  vendorLeadId  String?
  vendorUserId  String?
  vendorId      String
  vendor        LeadVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Contact
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  homePhone     String?
  workPhone     String?
  dob           String?
  ssn           String?

  // Co-borrower contact
  coFirstName   String?
  coLastName    String?
  coEmail       String?
  coPhone       String?
  coHomePhone   String?
  coWorkPhone   String?
  coDob         String?

  // Mailing address
  mailingAddress String?
  mailingCity    String?
  mailingState   String?
  mailingZip     String?
  mailingCounty  String?

  // Property address
  propertyAddress String?
  propertyCity    String?
  propertyState   String?
  propertyZip     String?
  propertyCounty  String?

  // Property
  purchasePrice  String?
  propertyValue  String?
  propertyType   String?
  propertyUse    String?
  propertyAcquired String?
  propertyLtv    String?

  // Employer (borrower)
  employer         String?
  jobTitle         String?
  employmentLength String?
  selfEmployed     String?
  income           String?
  bankruptcy       String?
  foreclosure      String?
  homeowner        String?

  // Employer (co-borrower)
  coEmployer         String?
  coJobTitle         String?
  coEmploymentLength String?
  coSelfEmployed     String?
  coIncome           String?

  // Loan
  loanPurpose    String?
  loanAmount     String?
  loanTerm       String?
  loanType       String?
  loanRate       String?
  downPayment    String?
  cashOut        String?
  creditRating   String?
  currentLender  String?
  currentBalance String?
  currentRate    String?
  currentPayment String?
  currentTerm    String?
  currentType    String?
  otherBalance   String?
  otherPayment   String?
  targetRate     String?
  vaStatus       String?
  vaLoan         String?
  isMilitary     String?
  fhaLoan        String?
  sourceUrl      String?

  // Vendor-provided meta
  leadCreated    String?
  price          String?

  // Routing / status
  status         LeadStatus  @default(UNASSIGNED)
  assignedUserId String?
  assignedUser   User?       @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?
  campaignId     String?
  campaign       LeadCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  source         String?

  rawPayload     Json        @default("{}")
  receivedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  notes          LeadNote[]
  dispatches     ServiceDispatch[]

  customData     Json        @default("{}")

  @@unique([vendorId, vendorLeadId])
  @@index([status])
  @@index([assignedUserId, status])
  @@index([campaignId])
  @@index([vendorId, receivedAt])
  @@index([propertyState])
  @@index([receivedAt])
  // Pagination / list-view indexes. The CRM and LO "My Leads" pages sort
  // by receivedAt DESC and page with large skip values; without covering
  // indexes, Postgres otherwise has to sort the full 100k+ row set per
  // page change. Source has its own index because the filter dropdown
  // runs a DISTINCT across every row.
  @@index([status, receivedAt(sort: Desc)])
  @@index([assignedUserId, receivedAt(sort: Desc)])
  @@index([campaignId, receivedAt(sort: Desc)])
  @@index([source])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // authorId is nullable so system-generated notes (e.g. from the Lead
  // Mailbox bridge, which ingests vendor-side notes before a user is in
  // the loop) can be persisted without a real author. UI treats null
  // author as "Lead Mailbox" / "System".
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model CsvColumnMapping {
  id         String   @id @default(uuid())
