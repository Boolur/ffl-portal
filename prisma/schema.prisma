// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN // @deprecated — retained for enum-value stability; existing rows backfilled to ADMIN_III. No new rows should use this.
  ADMIN_I
  ADMIN_II
  ADMIN_III
  MANAGER
  LOAN_OFFICER
  LOA
  DISCLOSURE_SPECIALIST
  VA
  VA_TITLE
  VA_HOI // Legacy role retained for compatibility; HOI routes to PROCESSOR_JR.
  VA_PAYOFF
  VA_APPRAISAL
  QC
  PROCESSOR_JR
  PROCESSOR_SR
}

enum LoanStage {
  INTAKE
  DISCLOSURES_PENDING
  DISCLOSURES_SENT
  DISCLOSURES_SIGNED
  SUBMIT_TO_UW_PREP
  QC_REVIEW
  PROCESSING
  CONDITIONAL_APPROVAL
  CLEAR_TO_CLOSE
  CLOSED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskKind {
  SUBMIT_DISCLOSURES
  SUBMIT_QC // Legacy workflow retained for historical reporting.
  SUBMIT_PROCESSING
  SUBMIT_PLUS_ONE
  LO_NEEDS_INFO
  VA_TITLE
  VA_HOI
  VA_PAYOFF
  VA_APPRAISAL
}

enum TaskAttachmentPurpose {
  PROOF
  STIP
  OTHER
}

enum DisclosureDecisionReason {
  APPROVE_INITIAL_DISCLOSURES
  MISSING_ITEMS
  OTHER
}

enum TaskWorkflowState {
  NONE
  WAITING_ON_LO
  WAITING_ON_LO_APPROVAL
  READY_TO_COMPLETE
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  RETRY
  SENT
  FAILED
}

enum NotificationOutboxEventType {
  TASK_WORKFLOW
  VA_FANOUT
  PLUS_ONE_SUBMITTED
}

enum LenderLinkType {
  PORTAL
  RATES
  GUIDE
  SUPPORT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  WORKING
  CONVERTED
  DEAD
  RETURNED
  UNASSIGNED
}

enum LeadDistributionMethod {
  ROUND_ROBIN
  MANUAL
}

enum LeadDuplicateHandling {
  NONE
  REJECT
  ALLOW
}

enum PayrollCompRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum PayrollLoanChannel {
  BROKER
  NON_DELEGATED
}

enum PayrollProcessingType {
  IN_HOUSE
  CONTRACT
  LENDER
  OTHER
}

enum PayrollUserClassification {
  BROKER
  RETAIL
  SUPPORT_STAFF
}

enum PayrollCompPlanType {
  BROKER
  RETAIL
}

enum PayrollLeadSource {
  LEAD_BUY
  MAILER
  WARM_TRANSFER
  REFERRAL
  RETURN_CLIENT
  OTHER
}

enum PayrollLeadProvidedBy {
  SELF_SOURCED
  COMPANY_PROVIDED
  BRANCH_PROVIDED
}

enum PayrollReimbursementTarget {
  SELF
  MANAGER
}

enum PayrollSplitPayType {
  PERCENT
  FLAT
  BOTH
}

enum PayrollSalaryFrequency {
  SEMI_MONTHLY
  MONTHLY
  ANNUALLY
}

enum PayrollSettingValueType {
  MONEY
  NUMBER
  TEXT
  BOOLEAN
}

enum PayrollFeeRuleKind {
  WIRE_FEE
  UNDERWRITING_FEE
  ORIGINATION_FEE
  ONE_DAY_INTEREST
  LENDER_CREDIT
  OTHER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String?   // Nullable for SSO users later
  role          UserRole
  roles         UserRole[] @default([])
  loQcTwoRowPilot Boolean @default(false)
  loDisclosureSubmissionEnabled Boolean @default(false)
  loQcSubmissionEnabled Boolean @default(true)
  processingAssignmentGroups String[] @default([])
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  loansAsLO        Loan[] @relation("LoanOfficer")
  loansAsSecondaryLO Loan[] @relation("LoanSecondaryOfficer")
  loansAsVisibilitySubmitter Loan[] @relation("LoanVisibilitySubmitter")
  loansAsProcessor Loan[] @relation("Processor")
  assignedTasks    Task[]
  uploadedTaskAttachments TaskAttachment[] @relation("TaskAttachmentsUploadedBy")
  uploadedClientDocuments ClientDocument[] @relation("ClientDocumentsUploadedBy")
  clientsOwned     Client[] @relation("ClientOwner")
  auditLogs        AuditLog[]
  pipelineStages   PipelineStage[]
  pipelineNotes    PipelineNote[]
  externalUsers    ExternalUser[]
  leadMailboxLeads LeadMailboxLead[]
  invitesCreated   InviteToken[] @relation("InvitesCreated")
  passwordResets   PasswordResetToken[]
  notifications    Notification[]

  // Lead distribution relations
  leads              Lead[]
  campaignMemberships CampaignMember[]
  leadQuota          UserLeadQuota?
  defaultForCampaigns LeadCampaign[] @relation("CampaignDefaultUser")
  leadNotes          LeadNote[]
  leadTeams          LeadUserTeamMember[]
  managedLeadTeams   LeadUserTeamManager[]
  integrationCredentials UserIntegrationCredential[]
  integrationServicePermissions UserIntegrationServicePermission[]

  // Payroll / compensation relations
  payrollCompPlans      PayrollCompPlan[] @relation("PayrollCompPlanLoanOfficer")
  payrollSplitRecipients PayrollCompSplit[] @relation("PayrollCompSplitRecipient")
  payrollRequests       PayrollCompRequest[] @relation("PayrollCompRequestLoanOfficer")
  payrollReviewedRequests PayrollCompRequest[] @relation("PayrollCompRequestReviewedBy")
  payrollPaidRequests   PayrollCompRequest[] @relation("PayrollCompRequestPaidBy")
  payrollEditedRequests PayrollCompRequest[] @relation("PayrollCompRequestEditedBy")
  payrollRequestSplits  PayrollCompRequestSplit[] @relation("PayrollCompRequestSplitRecipient")
  payrollUserSettings   PayrollUserSetting?
}

model Loan {
  id              String    @id @default(uuid())
  loanNumber      String    @unique // Internal ID
  borrowerName    String
  borrowerPhone   String?
  borrowerEmail   String?
  amount          Decimal   @db.Decimal(12, 2)
  program         String?   // e.g. "FHA 30yr Fixed"
  propertyAddress String?
  
  stage           LoanStage @default(INTAKE)
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])

  // Client grouping (future: full 1003 profile)
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id])
  
  // Assignments
  loanOfficerId   String
  loanOfficer     User      @relation("LoanOfficer", fields: [loanOfficerId], references: [id])
  secondaryLoanOfficerId String?
  secondaryLoanOfficer User? @relation("LoanSecondaryOfficer", fields: [secondaryLoanOfficerId], references: [id])
  visibilitySubmitterUserId String?
  visibilitySubmitterUser User? @relation("LoanVisibilitySubmitter", fields: [visibilitySubmitterUserId], references: [id])
  
  processorId     String?
  processor       User?     @relation("Processor", fields: [processorId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks           Task[]
  auditLogs       AuditLog[]
  pipelineNotes   PipelineNote[]
  leadMailboxLeads LeadMailboxLead[]
  payrollCompRequests PayrollCompRequest[]

  @@index([loanOfficerId, pipelineStageId])
  @@index([secondaryLoanOfficerId])
  @@index([visibilitySubmitterUserId])
  @@index([clientId])
}

model Task {
  id          String                 @id @default(uuid())
  title       String
  description String?
  status      TaskStatus             @default(PENDING)
  priority    TaskPriority           @default(NORMAL)
  kind        TaskKind?
  submissionData Json?
  disclosureReason DisclosureDecisionReason?
  workflowState TaskWorkflowState    @default(NONE)
  loanOfficerApprovedAt DateTime?
  parentTaskId String?
  
  // A task belongs to a loan
  loanId      String
  loan        Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)

  // A task can be assigned to a specific user OR a role (pool)
  assignedUserId String?
  assignedUser   User?      @relation(fields: [assignedUserId], references: [id])
  assignedRole   UserRole?

  dueDate     DateTime?
  completedAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parentTask  Task?      @relation("TaskParentChild", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks  Task[]     @relation("TaskParentChild")
  attachments TaskAttachment[]
  notifications Notification[]

  @@index([parentTaskId])
  @@index([workflowState])
  @@index([createdAt])
  @@index([assignedRole, dueDate])
  @@index([assignedRole, createdAt])
  @@index([assignedUserId, dueDate])
  @@index([assignedUserId, createdAt])
  @@index([kind, dueDate])
  @@index([kind, createdAt])
  @@index([loanId, dueDate])
  @@index([status, dueDate])
  @@index([loanId, updatedAt])
}

model Lender {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String?
  logoStoragePath String?
  logoFilename    String?
  logoUrl         String?
  portalUrl       String?
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contacts        LenderContact[]
  links           LenderLink[]

  @@unique([name])
  @@index([active, sortOrder])
}

model LenderContact {
  id         String   @id @default(uuid())
  lenderId   String
  lender     Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  notes      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lenderId, sortOrder])
}

model LenderLink {
  id         String         @id @default(uuid())
  lenderId   String
  lender     Lender         @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  label      String
  url        String
  linkType   LenderLinkType @default(PORTAL)
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([lenderId, sortOrder])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  eventLabel String
  title      String
  message    String
  href       String?
  createdAt  DateTime @default(now())
  readAt     DateTime?

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NotificationOutbox {
  id                String                     @id @default(uuid())
  eventType         NotificationOutboxEventType
  status            NotificationOutboxStatus   @default(PENDING)
  payload           Json
  idempotencyKey    String                     @unique
  attempts          Int                        @default(0)
  maxAttempts       Int                        @default(8)
  nextAttemptAt     DateTime                   @default(now())
  processingStartedAt DateTime?
  sentAt            DateTime?
  lastError         String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([eventType, status])
}

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Optional link back to a client document that was attached to this task
  clientDocumentId String?
  clientDocument   ClientDocument? @relation(fields: [clientDocumentId], references: [id], onDelete: SetNull)

  purpose      TaskAttachmentPurpose @default(OTHER)
  storagePath  String
  filename     String
  contentType  String
  sizeBytes    Int

  uploadedById String
  uploadedBy   User     @relation("TaskAttachmentsUploadedBy", fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([clientDocumentId])
}

model Client {
  id            String   @id @default(uuid())

  ownerId       String
  owner         User     @relation("ClientOwner", fields: [ownerId], references: [id])

  leadId        String?  // LeadMailbox lead_id / external id fallback until phone is known
  phone         String?  // unique per LO when present
  email         String?
  firstName     String?
  lastName      String?
  displayName   String?
  address       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loans         Loan[]
  documents     ClientDocument[]

  @@unique([ownerId, phone])
  @@unique([ownerId, leadId])
  @@index([ownerId, lastName])
}

model ClientDocument {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  storagePath  String
  filename     String
  contentType  String
  sizeBytes    Int

  // Organization
  folder       String?      // e.g. "STIPS", "INCOME", "ASSETS"
  tags         String[]     // freeform tags

  uploadedById String
  uploadedBy   User     @relation("ClientDocumentsUploadedBy", fields: [uploadedById], references: [id])

  taskAttachments TaskAttachment[]

  createdAt    DateTime @default(now())

  @@index([clientId, createdAt])
}

model TaskTemplate {
  id           String    @id @default(uuid())
  stage        LoanStage
  title        String
  description  String?
  assignedRole UserRole
  dueOffsetDays Int      @default(1) // Due date = stage_start + days
}

model AuditLog {
  id        String   @id @default(uuid())
  loanId    String?
  loan      Loan?    @relation(fields: [loanId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g. "STAGE_CHANGED", "TASK_COMPLETED"
  details   String?  // JSON or text
  createdAt DateTime @default(now())
}

model InviteToken {
  id          String   @id @default(uuid())
  token       String   @unique
  email       String
  name        String?
  role        UserRole
  createdById String
  createdBy   User     @relation("InvitesCreated", fields: [createdById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  @@index([userId])
}

model ExternalUser {
  id          String   @id @default(uuid())
  provider    String
  externalId  String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([userId])
}

model LeadMailboxLead {
  id          String   @id @default(uuid())
  leadId      String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payload     Json
  receivedAt  DateTime @default(now())

  @@index([userId, receivedAt])
}

model PipelineStage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  order       Int
  color       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loans       Loan[]

  @@index([userId, order])
}

model PipelineNote {
  id        String   @id @default(uuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([loanId, createdAt])
}

// ---------------------------------------------------------------------------
// Lead Distribution System
// ---------------------------------------------------------------------------

model LeadVendor {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  webhookSecret   String?
  fieldMapping    Json     @default("{}")
  routingTagField String   @default("routing_tag")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leads     Lead[]
  campaigns LeadCampaign[]
}

model LeadCampaign {
  id                  String                 @id @default(uuid())
  name                String
  description         String?
  vendorId            String
  vendor              LeadVendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  routingTag          String
  active              Boolean                @default(true)
  distributionMethod  LeadDistributionMethod @default(ROUND_ROBIN)
  independentRotation Boolean                @default(true)

  duplicateHandling   LeadDuplicateHandling  @default(NONE)
  defaultLeadStatus   String                 @default("NEW")
  enableUserQuotas    Boolean                @default(true)

  defaultUserId       String?
  defaultUser         User?                  @relation("CampaignDefaultUser", fields: [defaultUserId], references: [id], onDelete: SetNull)

  groupId             String?
  group               LeadCampaignGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  stateFilter         String[]               @default([])
  loanTypeFilter      String[]               @default([])

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  members  CampaignMember[]
  leads    Lead[]

  @@unique([vendorId, routingTag])
  @@index([vendorId])
  @@index([active])
  @@index([groupId])
}

model LeadCampaignGroup {
  id          String         @id @default(uuid())
  name        String
  description String?
  // Legacy single-color column; kept as a mirror of colors[0] so in-flight
  // reads during deploys can't crash on a missing column. New writes keep
  // both in sync. Safe to drop in a future migration once nothing reads it.
  color       String         @default("blue")
  colors      String[]       @default(["blue"])
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  campaigns   LeadCampaign[]

  @@unique([name])
  @@index([active])
}

model LeadUserTeam {
  id          String               @id @default(uuid())
  name        String
  description String?
  // See LeadCampaignGroup.color for why we keep the legacy mirror column.
  color       String               @default("blue")
  colors      String[]             @default(["blue"])
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  members     LeadUserTeamMember[]
  managers    LeadUserTeamManager[]

  @@unique([name])
  @@index([active])
}

model LeadUserTeamMember {
  id        String       @id @default(uuid())
  teamId    String
  team      LeadUserTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model LeadUserTeamManager {
  id        String       @id @default(uuid())
  teamId    String
  team      LeadUserTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

enum IntegrationServiceKind {
  CLIENT
  SERVER
}

enum IntegrationServiceTrigger {
  MANUAL
  ON_RECEIVE
  ON_ASSIGN
  ON_STATUS_CHANGE
  DELAY_AFTER_RECEIVE
  DELAY_AFTER_ASSIGN
}

enum IntegrationServiceMethod {
  GET
  POST_TEXT
  POST_FORM
  POST_JSON
  POST_XML
  POST_XML_TEXT
  POST_XML_SOAP
  PUT_JSON
  // Fixed-template transactional email. No URL/body/headers are used;
  // the dispatcher renders a hard-coded template and sends via
  // Microsoft Graph on behalf of MS_SENDER_EMAIL. Recipient = lead's
  // assigned LO. Currently only the "Broker Launch Notification" email
  // uses this method.
  EMAIL_BROKER_LAUNCH
}

enum IntegrationServiceScope {
  ANY
  SPECIFIC
}

enum ServiceDispatchStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model IntegrationService {
  id                    String                    @id @default(uuid())
  slug                  String                    @unique
  name                  String
  description           String?
  type                  String
  active                Boolean                   @default(true)
  config                Json                      @default("{}")

  kind                  IntegrationServiceKind    @default(CLIENT)
  statusTrigger         IntegrationServiceTrigger @default(MANUAL)
  triggerStatus         String?
  triggerDay            Int?
  triggerDelayMinutes   Int?

  method                IntegrationServiceMethod  @default(POST_JSON)
  urlTemplate           String                    @default("")
  bodyTemplate          String                    @default("")
  headersTemplate       String                    @default("")

  userScope             IntegrationServiceScope   @default(ANY)
  userIds               String[]                  @default([])
  campaignScope         IntegrationServiceScope   @default(ANY)
  campaignIds           String[]                  @default([])
  excludeSelected       Boolean                   @default(false)

  successString         String?
  failNotifyEmail       String?
  dateOverride          String?
  captureFields         Json                      @default("[]")

  requiresBrandNew      Boolean                   @default(false)
  requiresNotBrandNew   Boolean                   @default(false)
  requiresAssignedUser  Boolean                   @default(false)
  requiresOAuth         Boolean                   @default(false)
  allowManualSend       Boolean                   @default(true)

  oauthConfig           Json?

  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  credentialFields      IntegrationServiceCredentialField[]
  userCredentials       UserIntegrationCredential[]
  userPermissions       UserIntegrationServicePermission[]
  dispatches            ServiceDispatch[]

  @@index([active])
  @@index([statusTrigger, active])
}

model IntegrationServiceCredentialField {
  id          String             @id @default(uuid())
  serviceId   String
  service     IntegrationService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  key         String
  label       String
  required    Boolean            @default(false)
  secret      Boolean            @default(false)
  placeholder String?
  helpText    String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([serviceId, key])
  @@index([serviceId])
}

model UserIntegrationCredential {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   IntegrationService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  values    Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([userId, serviceId])
  @@index([serviceId])
}

// Per-user allow list: which IntegrationServices a non-admin user is
// permitted to manually push leads through. Empty = no services visible
// in the LO "Push to Service" picker. Admin/Manager bypass this table.
model UserIntegrationServicePermission {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   IntegrationService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  canPush   Boolean            @default(true)
  createdAt DateTime           @default(now())

  @@unique([userId, serviceId])
  @@index([serviceId])
}

model ServiceDispatch {
  id                String                @id @default(uuid())
  serviceId         String
  service           IntegrationService    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  leadId            String
  lead              Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  trigger           IntegrationServiceTrigger
  scheduledFor      DateTime              @default(now())
  status            ServiceDispatchStatus @default(PENDING)
  attempts          Int                   @default(0)
  lastError         String?
  skippedReason     String?
  requestSnapshot   Json?
  responseSnapshot  Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  completedAt       DateTime?

  @@index([status, scheduledFor])
  @@index([serviceId, status])
  @@index([leadId, serviceId])
  @@index([leadId, createdAt])
}

model CampaignMember {
  id                    String    @id @default(uuid())
  campaignId            String
  campaign              LeadCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyQuota            Int       @default(0)
  weeklyQuota           Int       @default(0)
  monthlyQuota          Int       @default(0)
  licensedStates        String[]  @default([])
  receiveDays           Int[]     @default([1, 2, 3, 4, 5])
  active                Boolean   @default(true)
  roundRobinPosition    Int       @default(0)
  leadsReceivedToday    Int       @default(0)
  leadsReceivedThisWeek Int       @default(0)
  leadsReceivedThisMonth Int      @default(0)
  lastAssignedAt        DateTime?

