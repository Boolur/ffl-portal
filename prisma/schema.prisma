// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  LOAN_OFFICER
  LOA
  DISCLOSURE_SPECIALIST
  VA
  VA_TITLE
  VA_HOI // Legacy role retained for compatibility; HOI routes to PROCESSOR_JR.
  VA_PAYOFF
  VA_APPRAISAL
  QC
  PROCESSOR_JR
  PROCESSOR_SR
}

enum LoanStage {
  INTAKE
  DISCLOSURES_PENDING
  DISCLOSURES_SENT
  DISCLOSURES_SIGNED
  SUBMIT_TO_UW_PREP
  QC_REVIEW
  PROCESSING
  CONDITIONAL_APPROVAL
  CLEAR_TO_CLOSE
  CLOSED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskKind {
  SUBMIT_DISCLOSURES
  SUBMIT_QC
  LO_NEEDS_INFO
  VA_TITLE
  VA_HOI
  VA_PAYOFF
  VA_APPRAISAL
}

enum TaskAttachmentPurpose {
  PROOF
  STIP
  OTHER
}

enum DisclosureDecisionReason {
  APPROVE_INITIAL_DISCLOSURES
  MISSING_ITEMS
  OTHER
}

enum TaskWorkflowState {
  NONE
  WAITING_ON_LO
  WAITING_ON_LO_APPROVAL
  READY_TO_COMPLETE
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  RETRY
  SENT
  FAILED
}

enum NotificationOutboxEventType {
  TASK_WORKFLOW
  VA_FANOUT
}

enum LenderLinkType {
  PORTAL
  RATES
  GUIDE
  SUPPORT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  WORKING
  CONVERTED
  DEAD
  RETURNED
  UNASSIGNED
}

enum LeadDistributionMethod {
  ROUND_ROBIN
  MANUAL
}

enum LeadDuplicateHandling {
  NONE
  REJECT
  ALLOW
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String?   // Nullable for SSO users later
  role          UserRole
  roles         UserRole[] @default([])
  loQcTwoRowPilot Boolean @default(false)
  loDisclosureSubmissionEnabled Boolean @default(false)
  loQcSubmissionEnabled Boolean @default(true)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  loansAsLO        Loan[] @relation("LoanOfficer")
  loansAsSecondaryLO Loan[] @relation("LoanSecondaryOfficer")
  loansAsVisibilitySubmitter Loan[] @relation("LoanVisibilitySubmitter")
  loansAsProcessor Loan[] @relation("Processor")
  assignedTasks    Task[]
  uploadedTaskAttachments TaskAttachment[] @relation("TaskAttachmentsUploadedBy")
  uploadedClientDocuments ClientDocument[] @relation("ClientDocumentsUploadedBy")
  clientsOwned     Client[] @relation("ClientOwner")
  auditLogs        AuditLog[]
  pipelineStages   PipelineStage[]
  pipelineNotes    PipelineNote[]
  externalUsers    ExternalUser[]
  leadMailboxLeads LeadMailboxLead[]
  invitesCreated   InviteToken[] @relation("InvitesCreated")
  passwordResets   PasswordResetToken[]
  notifications    Notification[]

  // Lead distribution relations
  leads              Lead[]
  campaignMemberships CampaignMember[]
  leadQuota          UserLeadQuota?
  defaultForCampaigns LeadCampaign[] @relation("CampaignDefaultUser")
  leadNotes          LeadNote[]
}

model Loan {
  id              String    @id @default(uuid())
  loanNumber      String    @unique // Internal ID
  borrowerName    String
  borrowerPhone   String?
  borrowerEmail   String?
  amount          Decimal   @db.Decimal(12, 2)
  program         String?   // e.g. "FHA 30yr Fixed"
  propertyAddress String?
  
  stage           LoanStage @default(INTAKE)
  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])

  // Client grouping (future: full 1003 profile)
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id])
  
  // Assignments
  loanOfficerId   String
  loanOfficer     User      @relation("LoanOfficer", fields: [loanOfficerId], references: [id])
  secondaryLoanOfficerId String?
  secondaryLoanOfficer User? @relation("LoanSecondaryOfficer", fields: [secondaryLoanOfficerId], references: [id])
  visibilitySubmitterUserId String?
  visibilitySubmitterUser User? @relation("LoanVisibilitySubmitter", fields: [visibilitySubmitterUserId], references: [id])
  
  processorId     String?
  processor       User?     @relation("Processor", fields: [processorId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks           Task[]
  auditLogs       AuditLog[]
  pipelineNotes   PipelineNote[]
  leadMailboxLeads LeadMailboxLead[]

  @@index([loanOfficerId, pipelineStageId])
  @@index([secondaryLoanOfficerId])
  @@index([visibilitySubmitterUserId])
  @@index([clientId])
}

model Task {
  id          String                 @id @default(uuid())
  title       String
  description String?
  status      TaskStatus             @default(PENDING)
  priority    TaskPriority           @default(NORMAL)
  kind        TaskKind?
  submissionData Json?
  disclosureReason DisclosureDecisionReason?
  workflowState TaskWorkflowState    @default(NONE)
  loanOfficerApprovedAt DateTime?
  parentTaskId String?
  
  // A task belongs to a loan
  loanId      String
  loan        Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)

  // A task can be assigned to a specific user OR a role (pool)
  assignedUserId String?
  assignedUser   User?      @relation(fields: [assignedUserId], references: [id])
  assignedRole   UserRole?

  dueDate     DateTime?
  completedAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parentTask  Task?      @relation("TaskParentChild", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks  Task[]     @relation("TaskParentChild")
  attachments TaskAttachment[]
  notifications Notification[]

  @@index([parentTaskId])
  @@index([workflowState])
  @@index([createdAt])
  @@index([assignedRole, dueDate])
  @@index([assignedRole, createdAt])
  @@index([assignedUserId, dueDate])
  @@index([assignedUserId, createdAt])
  @@index([kind, dueDate])
  @@index([kind, createdAt])
  @@index([loanId, dueDate])
  @@index([status, dueDate])
  @@index([loanId, updatedAt])
}

model Lender {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String?
  logoStoragePath String?
  logoFilename    String?
  logoUrl         String?
  portalUrl       String?
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contacts        LenderContact[]
  links           LenderLink[]

  @@unique([name])
  @@index([active, sortOrder])
}

model LenderContact {
  id         String   @id @default(uuid())
  lenderId   String
  lender     Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  notes      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lenderId, sortOrder])
}

model LenderLink {
  id         String         @id @default(uuid())
  lenderId   String
  lender     Lender         @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  label      String
  url        String
  linkType   LenderLinkType @default(PORTAL)
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([lenderId, sortOrder])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  eventLabel String
  title      String
  message    String
  href       String?
  createdAt  DateTime @default(now())
  readAt     DateTime?

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NotificationOutbox {
  id                String                     @id @default(uuid())
  eventType         NotificationOutboxEventType
  status            NotificationOutboxStatus   @default(PENDING)
  payload           Json
  idempotencyKey    String                     @unique
  attempts          Int                        @default(0)
  maxAttempts       Int                        @default(8)
  nextAttemptAt     DateTime                   @default(now())
  processingStartedAt DateTime?
  sentAt            DateTime?
  lastError         String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([eventType, status])
}

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Optional link back to a client document that was attached to this task
  clientDocumentId String?
  clientDocument   ClientDocument? @relation(fields: [clientDocumentId], references: [id], onDelete: SetNull)

  purpose      TaskAttachmentPurpose @default(OTHER)
  storagePath  String
  filename     String
  contentType  String
  sizeBytes    Int

  uploadedById String
  uploadedBy   User     @relation("TaskAttachmentsUploadedBy", fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([clientDocumentId])
}

model Client {
  id            String   @id @default(uuid())

  ownerId       String
  owner         User     @relation("ClientOwner", fields: [ownerId], references: [id])

  leadId        String?  // LeadMailbox lead_id / external id fallback until phone is known
  phone         String?  // unique per LO when present
  email         String?
  firstName     String?
  lastName      String?
  displayName   String?
  address       String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loans         Loan[]
  documents     ClientDocument[]

  @@unique([ownerId, phone])
  @@unique([ownerId, leadId])
  @@index([ownerId, lastName])
}

model ClientDocument {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  storagePath  String
  filename     String
  contentType  String
  sizeBytes    Int

  // Organization
  folder       String?      // e.g. "STIPS", "INCOME", "ASSETS"
  tags         String[]     // freeform tags

  uploadedById String
  uploadedBy   User     @relation("ClientDocumentsUploadedBy", fields: [uploadedById], references: [id])

  taskAttachments TaskAttachment[]

  createdAt    DateTime @default(now())

  @@index([clientId, createdAt])
}

model TaskTemplate {
  id           String    @id @default(uuid())
  stage        LoanStage
  title        String
  description  String?
  assignedRole UserRole
  dueOffsetDays Int      @default(1) // Due date = stage_start + days
}

model AuditLog {
  id        String   @id @default(uuid())
  loanId    String?
  loan      Loan?    @relation(fields: [loanId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g. "STAGE_CHANGED", "TASK_COMPLETED"
  details   String?  // JSON or text
  createdAt DateTime @default(now())
}

model InviteToken {
  id          String   @id @default(uuid())
  token       String   @unique
  email       String
  name        String?
  role        UserRole
  createdById String
  createdBy   User     @relation("InvitesCreated", fields: [createdById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  @@index([userId])
}

model ExternalUser {
  id          String   @id @default(uuid())
  provider    String
  externalId  String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
  @@index([userId])
}

model LeadMailboxLead {
  id          String   @id @default(uuid())
  leadId      String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payload     Json
  receivedAt  DateTime @default(now())

  @@index([userId, receivedAt])
}

model PipelineStage {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  order       Int
  color       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loans       Loan[]

  @@index([userId, order])
}

model PipelineNote {
  id        String   @id @default(uuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([loanId, createdAt])
}

// ---------------------------------------------------------------------------
// Lead Distribution System
// ---------------------------------------------------------------------------

model LeadVendor {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  webhookSecret   String?
  fieldMapping    Json     @default("{}")
  routingTagField String   @default("routing_tag")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leads     Lead[]
  campaigns LeadCampaign[]
}

model LeadCampaign {
  id                  String                 @id @default(uuid())
  name                String
  description         String?
  vendorId            String
  vendor              LeadVendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  routingTag          String
  active              Boolean                @default(true)
  distributionMethod  LeadDistributionMethod @default(ROUND_ROBIN)
  independentRotation Boolean                @default(true)

  duplicateHandling   LeadDuplicateHandling  @default(NONE)
  defaultLeadStatus   String                 @default("NEW")
  enableUserQuotas    Boolean                @default(true)

  defaultUserId       String?
  defaultUser         User?                  @relation("CampaignDefaultUser", fields: [defaultUserId], references: [id], onDelete: SetNull)

  groupId             String?
  group               LeadCampaignGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  stateFilter         String[]               @default([])
  loanTypeFilter      String[]               @default([])

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  members  CampaignMember[]
  leads    Lead[]

  @@unique([vendorId, routingTag])
  @@index([vendorId])
  @@index([active])
  @@index([groupId])
}

model LeadCampaignGroup {
  id          String         @id @default(uuid())
  name        String
  description String?
  color       String         @default("blue")
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  campaigns   LeadCampaign[]

  @@unique([name])
  @@index([active])
}

model CampaignMember {
  id                    String    @id @default(uuid())
  campaignId            String
  campaign              LeadCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyQuota            Int       @default(0)
  weeklyQuota           Int       @default(0)
  monthlyQuota          Int       @default(0)
  licensedStates        String[]  @default([])
  receiveDays           Int[]     @default([1, 2, 3, 4, 5])
  active                Boolean   @default(true)
  roundRobinPosition    Int       @default(0)
  leadsReceivedToday    Int       @default(0)
  leadsReceivedThisWeek Int       @default(0)
  leadsReceivedThisMonth Int      @default(0)
  lastAssignedAt        DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId, active, roundRobinPosition])
  @@index([userId])
}

model UserLeadQuota {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  leadsEnabled          Boolean  @default(true)
  licensedStates        String[] @default([])
  bonzoWebhookUrl       String?

  globalDailyQuota      Int      @default(0)
  globalWeeklyQuota     Int      @default(0)
  globalMonthlyQuota    Int      @default(0)
  leadsReceivedToday    Int      @default(0)
  leadsReceivedThisWeek Int      @default(0)
  leadsReceivedThisMonth Int     @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Lead {
  id            String      @id @default(uuid())
  vendorLeadId  String?
  vendorUserId  String?
  vendorId      String
  vendor        LeadVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Contact
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  homePhone     String?
  workPhone     String?
  dob           String?
  ssn           String?

  // Co-borrower contact
  coFirstName   String?
  coLastName    String?
  coEmail       String?
  coPhone       String?
  coHomePhone   String?
  coWorkPhone   String?
  coDob         String?

  // Mailing address
  mailingAddress String?
  mailingCity    String?
  mailingState   String?
  mailingZip     String?
  mailingCounty  String?

  // Property address
  propertyAddress String?
  propertyCity    String?
  propertyState   String?
  propertyZip     String?
  propertyCounty  String?

  // Property
  purchasePrice  String?
  propertyValue  String?
  propertyType   String?
  propertyUse    String?
  propertyAcquired String?
  propertyLtv    String?

  // Employer (borrower)
  employer         String?
  jobTitle         String?
  employmentLength String?
  selfEmployed     String?
  income           String?
  bankruptcy       String?
  foreclosure      String?
  homeowner        String?

  // Employer (co-borrower)
  coEmployer         String?
  coJobTitle         String?
  coEmploymentLength String?
  coSelfEmployed     String?
  coIncome           String?

  // Loan
  loanPurpose    String?
  loanAmount     String?
  loanTerm       String?
  loanType       String?
  loanRate       String?
  downPayment    String?
  cashOut        String?
  creditRating   String?
  currentLender  String?
  currentBalance String?
  currentRate    String?
  currentPayment String?
  currentTerm    String?
  currentType    String?
  otherBalance   String?
  otherPayment   String?
  targetRate     String?
  vaStatus       String?
  vaLoan         String?
  isMilitary     String?
  fhaLoan        String?
  sourceUrl      String?

  // Vendor-provided meta
  leadCreated    String?
  price          String?

  // Routing / status
  status         LeadStatus  @default(UNASSIGNED)
  assignedUserId String?
  assignedUser   User?       @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?
  campaignId     String?
  campaign       LeadCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  source         String?

  rawPayload     Json        @default("{}")
  receivedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  notes          LeadNote[]

  @@unique([vendorId, vendorLeadId])
  @@index([status])
  @@index([assignedUserId, status])
  @@index([campaignId])
  @@index([vendorId, receivedAt])
  @@index([propertyState])
  @@index([receivedAt])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // authorId is nullable so system-generated notes (e.g. from the Lead
  // Mailbox bridge, which ingests vendor-side notes before a user is in
  // the loop) can be persisted without a real author. UI treats null
  // author as "Lead Mailbox" / "System".
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model CsvColumnMapping {
  id         String   @id @default(uuid())
  csvHeader  String
  ourField   String
  usageCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([csvHeader, ourField])
  @@index([csvHeader])
}
